<UserControl x:Class="CodexBarTray.UsagePopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MaxHeight="560" Width="340">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="PanelBg" Color="#FF15151A" />
        <SolidColorBrush x:Key="TrackBg" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF2F2F4" />
        <SolidColorBrush x:Key="TextDim" Color="#FF9A9AA2" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE0483B" />

        <!-- Flat rounded usage bar -->
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{StaticResource TrackBg}" CornerRadius="3" />
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- One rate-limit window row -->
        <DataTemplate x:Key="WindowTemplate">
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}"
                           Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ProgressBar Style="{StaticResource UsageBar}"
                                 Value="{Binding UsedPercent, Mode=OneWay}"
                                 Foreground="{Binding BarBrush}" />
                    <TextBlock Text="{Binding ResetText}" Foreground="{StaticResource TextDim}"
                               FontSize="10" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding PercentText}"
                           Foreground="{StaticResource TextPrimary}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <!-- One provider tile -->
        <DataTemplate x:Key="ProviderTemplate">
            <Border Background="#22FFFFFF" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Account}" Foreground="{StaticResource TextDim}"
                                   FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180"
                                   Visibility="{Binding HasAccount, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Windows}"
                                  ItemTemplate="{StaticResource WindowTemplate}"
                                  Visibility="{Binding HasWindows, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                               FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBg}" CornerRadius="12" Padding="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <Grid Margin="0,0,0,10">
                <TextBlock Text="CodexBar" Foreground="{StaticResource TextPrimary}"
                           FontSize="15" FontWeight="Bold" />
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextDim}"
                           FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
            <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Providers}"
                              ItemTemplate="{StaticResource ProviderTemplate}" />
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
