<Window x:Class="CodexBarTray.UsageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <!-- Transparent margin leaves room for the panel's drop shadow and gives a
         drag surface around the content. -->
    <ContentControl x:Name="Host" Margin="18" />
</Window>
