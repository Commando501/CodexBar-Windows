<Window x:Class="CodexBarTray.DesktopWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar Widget"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="PanelBg" Color="#FF15151A" />
        <SolidColorBrush x:Key="TrackBg" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF2F2F4" />
        <SolidColorBrush x:Key="TextDim" Color="#FF9A9AA2" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFE0483B" />

        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{StaticResource TrackBg}" CornerRadius="3" />
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="WidgetWindowTemplate">
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}"
                           Foreground="{StaticResource TextDim}" FontSize="11" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ProgressBar Style="{StaticResource UsageBar}"
                                 Value="{Binding UsedPercent, Mode=OneWay}"
                                 Foreground="{Binding BarBrush}" />
                    <TextBlock Text="{Binding ResetText}" Foreground="{StaticResource TextDim}"
                               FontSize="10" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding PercentText}"
                           Foreground="{StaticResource TextPrimary}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Refresh" Click="OnRefreshClick" />
            <MenuItem Header="Remove widget" Click="OnRemoveClick" />
        </ContextMenu>
    </Window.ContextMenu>

    <!-- Transparent margin leaves room for the drop shadow + a drag surface. -->
    <Border Margin="12" Background="{StaticResource PanelBg}" CornerRadius="12" Padding="12,10" Width="216">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <Grid>
                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="CloseButton" Text="✕" Foreground="{StaticResource TextDim}"
                           FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Cursor="Hand" Padding="4,0" ToolTip="Remove widget" />
            </Grid>
            <TextBlock Text="{Binding Provider.Account}" Foreground="{StaticResource TextDim}"
                       FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                       Visibility="{Binding Provider.HasAccount, Converter={StaticResource BoolToVis}}" />

            <ItemsControl ItemsSource="{Binding Provider.Windows}"
                          ItemTemplate="{StaticResource WidgetWindowTemplate}"
                          Visibility="{Binding Provider.HasWindows, Converter={StaticResource BoolToVis}}" />

            <TextBlock Text="{Binding Provider.ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                       Visibility="{Binding Provider.HasError, Converter={StaticResource BoolToVis}}" />

            <TextBlock Text="Waiting for data…" Foreground="{StaticResource TextDim}"
                       FontSize="11" Margin="0,4,0,0"
                       Visibility="{Binding NoData, Converter={StaticResource BoolToVis}}" />
        </StackPanel>
    </Border>
</Window>
